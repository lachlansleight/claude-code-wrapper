# Copy to plugin/src/.env (gitignored) for local development.
# `npm run dev` (and `npm start` after build) will pick this up
# automatically. Real shell exports always override these values.

BRIDGE_TOKEN=dev
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787

# Optional — mirror logs to a file as well as stderr.
# BRIDGE_LOG_FILE=./bridge.log

# Optional — Firebase RTDB sync. Both required if used.
# BRIDGE_DATABASE_URL=https://your-db.firebaseio.com
# BRIDGE_AGENT_ID=your-agent-id
