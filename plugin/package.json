{
  "name": "agent-bridge",
  "version": "0.2.0",
  "description": "Agent-agnostic HTTP/WebSocket bridge that normalizes lifecycle hooks from Claude Code, Codex, Cursor, and OpenCode into a shared personality-state stream.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-bridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build:watch": "tsc --watch"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
