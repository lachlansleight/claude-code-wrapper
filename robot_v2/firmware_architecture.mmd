flowchart TD
    classDef cfg    fill:#2d2a14,stroke:#d4b400,color:#fff
    classDef net    fill:#0f2540,stroke:#4a90e2,color:#fff
    classDef state  fill:#1b3a1b,stroke:#5cb85c,color:#fff
    classDef face   fill:#3a1b3a,stroke:#c060c0,color:#fff
    classDef motion fill:#3a2415,stroke:#e0883a,color:#fff

    PRV["Provisioning<br/><i>NVS + AP config portal<br/>(WiFi/bridge creds)</i>"]:::cfg

    WIFI["WiFiManager<br/><i>connect + auto-reconnect</i>"]:::net
    BRIDGE["BridgeClient<br/><i>WebSocket transport,<br/>JSON decode, send helpers</i>"]:::net

    AE["AgentEvents<br/><i>event structs, polled state,<br/>callback registry, session latching</i>"]:::state
    PER["Personality<br/><i>state machine: 12 states<br/>(IDLE/THINKING/READING/...)</i>"]:::state

    FACE["Face<br/><i>per-state FaceParams + tween +<br/>blink/breath/gaze/tilt modulators</i>"]:::face
    DISP["Display<br/><i>TFT_eSPI sprite framebuffer,<br/>DMA push to GC9A01</i>"]:::face

    MB["MotionBehaviors<br/><i>state-driven arm gestures</i>"]:::motion
    MOT["Motion<br/><i>servo abstraction +<br/>non-blocking keyframes</i>"]:::motion

    PRV -- "creds" --> WIFI
    PRV -- "host/port/token" --> BRIDGE
    WIFI -. "link up" .-> BRIDGE

    BRIDGE -- "parsed envelopes" --> AE
    AE -- "events / state" --> PER
    AE -- "tool counts" --> FACE

    PER -- "current state" --> FACE
    PER -- "current state" --> MB

    FACE -- "writes sprite" --> DISP
    MB -- "drives keyframes" --> MOT
